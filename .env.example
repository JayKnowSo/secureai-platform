# ── SECUREAI PLATFORM — ENVIRONMENT VARIABLES ───────────────────────
# This file is SAFE TO COMMIT — it contains no real secrets
# It shows other developers (and recruiters) what variables are needed
# Copy this file to .env and fill in your real values:
#   cp .env.example .env

# ── AI ANALYSIS ─────────────────────────────────────────────────────
# Anthropic API Key — powers the AI CVE analysis feature
# Used by: secureai analyze cve <CVE-ID>
# Get yours at: https://console.anthropic.com
# Free credits available on new accounts
ANTHROPIC_API_KEY=your-api-key-here

# ── SCANNER SETTINGS ────────────────────────────────────────────────
# Severity threshold — findings below this level are reported but not flagged
# Options: CRITICAL, HIGH, MEDIUM, LOW
# Default: HIGH — flags CRITICAL and HIGH findings
# In a CI/CD pipeline set to CRITICAL to only fail on the most serious issues
SECUREAI_SEVERITY_THRESHOLD=HIGH

# ── REPORT SETTINGS ─────────────────────────────────────────────────
# Output directory for generated HTML security reports
# Default: reports/ (created automatically if it doesn't exist)
SECUREAI_REPORT_OUTPUT_DIR=reports/

# ── NVD API (Phase 3 — Real-time CVE Monitoring) ────────────────────
# National Vulnerability Database API key
# Free at: https://nvd.nist.gov/developers/request-an-api-key
# Not required for Phase 1 — used in Phase 3 CVE monitoring module
NVD_API_KEY=your-nvd-api-key-here

# ── AWS (Phase 2 — Infrastructure Auditor) ──────────────────────────
# AWS credentials for the Well-Architected auditor module
# Never hardcode these — always use environment variables or IAM roles
# In production: use IAM roles instead of access keys
AWS_ACCESS_KEY_ID=your-access-key-here
AWS_SECRET_ACCESS_KEY=your-secret-key-here
AWS_DEFAULT_REGION=us-east-1