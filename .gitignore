# ── PYTHON ──────────────────────────────────────────────────────────
# .venv and venv = your virtual environment folders
# Never commit these — they contain thousands of library files
# Anyone cloning the repo runs: python -m venv .venv && pip install -r requirements.txt
.venv/
venv/

# Python compiles .py files into bytecode for faster execution
# __pycache__ = folder containing compiled bytecode files (.pyc)
# These are machine-specific and auto-generated — never commit
__pycache__/
*.pyc    # compiled Python bytecode
*.pyo    # optimized compiled bytecode

# When you pip install -e . (editable install) Python creates these
# Contains metadata about your package — auto-generated, not needed in repo
*.egg-info/
dist/    # built distribution packages
build/   # build artifacts

# ── ENVIRONMENT & SECRETS ───────────────────────────────────────────
# .env contains your real secrets — API keys, passwords, tokens
# NEVER commit this file — it would expose credentials on GitHub forever
# Git history doesn't forget — even if you delete it later
# .env.example is committed instead — shows what variables are needed
.env

# ── SECUREAI OUTPUT ─────────────────────────────────────────────────
# reports/ is where SecureAI writes its HTML security reports
# These are generated output — not source code
# Each scan generates a new report — no need to version control them
reports/

# ── TESTING ─────────────────────────────────────────────────────────
# pytest creates .pytest_cache when tests run
# Contains test results cache to speed up reruns — machine specific
.pytest_cache/

# .coverage is generated by pytest-cov (coverage reporting tool)
# Shows which lines of code were executed during tests
.coverage

# ── IDE & EDITOR ────────────────────────────────────────────────────
# .vscode = VSCode workspace settings, extensions, launch configs
# These are personal preferences — not part of the project
# Another developer might use PyCharm, vim, etc.
.vscode/
.idea/   # PyCharm settings

# ── OPERATING SYSTEM ────────────────────────────────────────────────
# macOS creates .DS_Store files in every folder it opens
# These are invisible metadata files — pure noise in a repo
.DS_Store